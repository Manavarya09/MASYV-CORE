---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HELIOS - Futuristic AI Command System">
  <main class="container">
    <div class="grid-bg"></div>
    
    <section class="hero">
      <div class="badge">v0.8.0 Released</div>
      <h1>HELIOS</h1>
      <p class="tagline">A futuristic AI command system built with Rust and egui</p>
      
      <div class="buttons">
        <a href="https://github.com/Manavarya09/HELIOS" class="btn-primary">Get Started</a>
        <a href="#features" class="btn-secondary">Explore Features</a>
      </div>
    </section>

    <section id="features" class="features">
      <h2>Features</h2>
      
      <div class="grid">
        <div class="card">
          <h3>AI Integration</h3>
          <p>Multi-provider support for Ollama, OpenAI, Anthropic, Claude, Gemini, and DeepSeek</p>
        </div>
        
        <div class="card">
          <h3>Real-Time Metrics</h3>
          <p>CPU, Memory, Network, Power, GPU, and Disk monitoring with live graphs</p>
        </div>
        
        <div class="card">
          <h3>7 Themes</h3>
          <p>Dark, Light, Cyberpunk, Ocean, Forest, Neon, and Matrix themes</p>
        </div>
        
        <div class="card">
          <h3>Plugin System</h3>
          <p>Extensible architecture with hot-reload support</p>
        </div>
        
        <div class="card">
          <h3>JARVIS Core</h3>
          <p>System status with encryption, shield, and integrity monitoring</p>
        </div>
        
        <div class="card">
          <h3>Voice System</h3>
          <p>TTS/STT support with configurable voice</p>
        </div>
      </div>
    </section>

    <section class="code-preview">
      <div class="terminal">
        <div class="terminal-header">
          <div class="dots">
            <span class="red"></span>
            <span class="yellow"></span>
            <span class="green"></span>
          </div>
          <span class="title">terminal</span>
        </div>
        <div class="terminal-body">
          <div class="prompt">$</div>
          <div class="cmd">> ai What is Rust?</div>
          <div class="response">Rust is a systems programming language that focuses on safety, performance, and concurrency. It provides memory safety without garbage collection.</div>
          <div class="prompt">$</div>
          <div class="cmd">> stats</div>
          <div class="stats">
            <span><span class="label">CPU</span> <span class="value">23%</span></span>
            <span><span class="label">MEM</span> <span class="value">8.2GB</span></span>
            <span><span class="label">GPU</span> <span class="value">45%</span></span>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <p>HELIOS - Built with Rust and egui</p>
      <div class="links">
        <a href="https://github.com/Manavarya09/HELIOS">GitHub</a>
        <a href="https://github.com/Manavarya09/HELIOS/issues">Issues</a>
        <a href="https://github.com/Manavarya09/HELIOS/discussions">Discussions</a>
      </div>
    </footer>
  </main>
</Layout>

<style is:inline>
.container {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  background: #000;
}
.grid-bg {
  position: fixed;
  inset: 0;
  background-image: 
    linear-gradient(rgba(6, 182, 212, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(6, 182, 212, 0.03) 1px, transparent 1px);
  background-size: 50px 50px;
  pointer-events: none;
}
.hero {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 2rem;
  text-align: center;
}
.badge {
  display: inline-block;
  padding: 0.375rem 1rem;
  margin-bottom: 1.5rem;
  font-family: monospace;
  font-size: 0.875rem;
  color: #22d3ee;
  border: 1px solid rgba(34, 211, 238, 0.3);
  border-radius: 9999px;
  background: rgba(34, 211, 238, 0.05);
}
h1 {
  font-size: 4rem;
  font-weight: 700;
  letter-spacing: -0.025em;
  margin: 0 0 1.5rem 0;
  color: #fff;
}
.tagline {
  font-size: 1.25rem;
  color: #9ca3af;
  max-width: 42rem;
  margin: 0 0 2.5rem 0;
}
.buttons {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}
.btn-primary {
  padding: 0.75rem 2rem;
  background: #06b6d4;
  color: #000;
  font-weight: 600;
  border-radius: 0.5rem;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-primary:hover {
  background: #22d3ee;
}
.btn-secondary {
  padding: 0.75rem 2rem;
  border: 1px solid #374151;
  color: #fff;
  border-radius: 0.5rem;
  text-decoration: none;
  transition: border-color 0.2s;
}
.btn-secondary:hover {
  border-color: #4b5563;
}
.features {
  position: relative;
  z-index: 10;
  padding: 5rem 2rem;
}
.features h2 {
  font-size: 2.25rem;
  font-weight: 700;
  text-align: center;
  color: #fff;
  margin: 0 0 4rem 0;
}
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  max-width: 72rem;
  margin: 0 auto;
}
.card {
  padding: 1.5rem;
  border: 1px solid #1f2937;
  border-radius: 0.75rem;
  background: rgba(31, 41, 55, 0.5);
  transition: border-color 0.2s;
}
.card:hover {
  border-color: rgba(34, 211, 238, 0.5);
}
.card h3 {
  font-size: 1.25rem;
  font-weight: 600;
  color: #fff;
  margin: 0 0 0.75rem 0;
}
.card p {
  color: #9ca3af;
  margin: 0;
}
.code-preview {
  position: relative;
  z-index: 10;
  padding: 4rem 2rem;
}
.terminal {
  max-width: 56rem;
  margin: 0 auto;
  border-radius: 0.75rem;
  border: 1px solid #1f2937;
  overflow: hidden;
}
.terminal-header {
  display: flex;
  align-items: center;
  padding: 0.75rem 1rem;
  background: #111827;
  border-bottom: 1px solid #1f2937;
}
.dots {
  display: flex;
  gap: 0.5rem;
}
.dots span {
  width: 0.75rem;
  height: 0.75rem;
  border-radius: 50%;
}
.red { background: #ef4444; }
.yellow { background: #eab308; }
.green { background: #22c55e; }
.title {
  margin-left: 1rem;
  font-size: 0.875rem;
  color: #6b7280;
}
.terminal-body {
  padding: 1.5rem;
  background: #000;
  font-family: monospace;
  font-size: 0.875rem;
  overflow-x: auto;
}
.prompt { color: #6b7280; }
.cmd { color: #22d3ee; margin-top: 0.25rem; }
.response { color: #9ca3af; margin-top: 0.5rem; }
.stats { display: flex; gap: 2rem; margin-top: 0.5rem; }
.stats .label { color: #6b7280; }
.stats .value { color: #fff; }
footer {
  position: relative;
  z-index: 10;
  padding: 3rem 2rem;
  border-top: 1px solid #1f2937;
  text-align: center;
}
footer p {
  color: #6b7280;
  margin: 0;
}
.links {
  display: flex;
  justify-content: center;
  gap: 1.5rem;
  margin-top: 1rem;
}
.links a {
  color: #9ca3af;
  text-decoration: none;
  transition: color 0.2s;
}
.links a:hover {
  color: #fff;
}
@media (min-width: 768px) {
  h1 { font-size: 4.5rem; }
  .tagline { font-size: 1.5rem; }
}
</style>