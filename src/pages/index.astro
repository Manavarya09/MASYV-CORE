---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HELIOS - Futuristic AI Command System">
  <main class="container">
    <div class="grid-bg"></div>
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <div class="badge">
          <span class="badge-dot"></span>
          v0.8.0 Released
        </div>
        <h1 class="hero-title">
          <span class="title-line">HELIOS</span>
        </h1>
        <p class="hero-subtitle">A futuristic AI command system built with Rust and egui</p>
        <p class="hero-desc">
          HELIOS is a professional GUI application featuring real-time system metrics, 
          multi-provider AI integration, extensible plugin architecture, and a futuristic interface 
          with 7 theme options.
        </p>
        <div class="hero-actions">
          <a href="https://github.com/Manavarya09/HELIOS" class="btn btn-primary">
            <span class="btn-icon">+</span>
            Get Started
          </a>
          <a href="#features" class="btn btn-secondary">
            Explore Features
            <span class="btn-arrow">-></span>
          </a>
        </div>
      </div>
      
      <!-- Hero Visual -->
      <div class="hero-visual">
        <div class="visual-frame">
          <div class="frame-header">
            <div class="frame-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="frame-title">HELIOS v0.8.0</span>
          </div>
          <div class="frame-body">
            <div class="metrics-grid">
              <div class="metric">
                <span class="metric-label">CPU</span>
                <div class="metric-bar"><div class="metric-fill" style="width: 23%"></div></div>
                <span class="metric-value">23%</span>
              </div>
              <div class="metric">
                <span class="metric-label">MEM</span>
                <div class="metric-bar"><div class="metric-fill" style="width: 41%"></div></div>
                <span class="metric-value">8.2GB</span>
              </div>
              <div class="metric">
                <span class="metric-label">GPU</span>
                <div class="metric-bar"><div class="metric-fill" style="width: 45%"></div></div>
                <span class="metric-value">45%</span>
              </div>
              <div class="metric">
                <span class="metric-label">DISK</span>
                <div class="metric-bar"><div class="metric-fill" style="width: 67%"></div></div>
                <span class="metric-value">67%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
      <div class="section-header">
        <h2>About HELIOS</h2>
        <p class="section-desc">A next-generation command interface for the modern era</p>
      </div>
      <div class="about-grid">
        <div class="about-card">
          <div class="about-icon">
            <div class="icon-frame"></div>
          </div>
          <h3>Built with Rust</h3>
          <p>Leveraging Rust's performance and safety for a lightning-fast, error-free experience. Native performance with memory safety guaranteed.</p>
        </div>
        <div class="about-card">
          <div class="about-icon">
            <div class="icon-frame"></div>
          </div>
          <h3>egui Framework</h3>
          <p>Powered by egui for immediate mode rendering. Smooth 60fps GUI with minimal overhead.</p>
        </div>
        <div class="about-card">
          <div class="about-icon">
            <div class="icon-frame"></div>
          </div>
          <h3>AI-Powered</h3>
          <p>Integrate with Ollama, OpenAI, Anthropic, Claude, Gemini, or DeepSeek. Your AI assistant, your rules.</p>
        </div>
        <div class="about-card">
          <div class="about-icon">
            <div class="icon-frame"></div>
          </div>
          <h3>Extensible</h3>
          <p>Plugin system with hot-reload support. Extend functionality without restarting the application.</p>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features">
      <div class="section-header">
        <h2>Features</h2>
        <p class="section-desc">Everything you need for a powerful command experience</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">01</div>
            <h3>AI Integration</h3>
          </div>
          <p>Multi-provider support for Ollama, OpenAI, Anthropic, Claude, Gemini, and DeepSeek. Streaming responses with chat history.</p>
          <div class="feature-tags">
            <span>Ollama</span>
            <span>OpenAI</span>
            <span>Anthropic</span>
          </div>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">02</div>
            <h3>Real-Time Metrics</h3>
          </div>
          <p>CPU, Memory, Network, Power, GPU, and Disk monitoring with live graphs. Stay informed at a glance.</p>
          <div class="feature-tags">
            <span>CPU</span>
            <span>GPU</span>
            <span>Network</span>
          </div>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">03</div>
            <h3>7 Themes</h3>
          </div>
          <p>Dark, Light, Cyberpunk, Ocean, Forest, Neon, and Matrix themes. Customize your workspace.</p>
          <div class="feature-tags">
            <span>Dark</span>
            <span>Neon</span>
            <span>Matrix</span>
          </div>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">04</div>
            <h3>Plugin System</h3>
          </div>
          <p>Extensible architecture with hot-reload support. Build and load custom plugins effortlessly.</p>
          <div class="feature-tags">
            <span>Hot-Reload</span>
            <span>API</span>
          </div>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">05</div>
            <h3>JARVIS Core</h3>
          </div>
          <p>System status with encryption, shield, and integrity monitoring. Your digital assistant, secured.</p>
          <div class="feature-tags">
            <span>Encryption</span>
            <span>Shield</span>
          </div>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">06</div>
            <h3>Voice System</h3>
          </div>
          <p>TTS/STT support with configurable voice. Interact with HELIOS using voice commands.</p>
          <div class="feature-tags">
            <span>TTS</span>
            <span>STT</span>
          </div>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">07</div>
            <h3>File Operations</h3>
          </div>
          <p>Complete file management: ls, cd, pwd, read, write, mkdir, delete. Full shell integration.</p>
          <div class="feature-tags">
            <span>Shell</span>
            <span>Files</span>
          </div>
        </div>
        
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-num">08</div>
            <h3>Network Tools</h3>
          </div>
          <p>Built-in tools: ping, curl, port scanning, network diagnostics. Monitor your network status.</p>
          <div class="feature-tags">
            <span>Ping</span>
            <span>Curl</span>
            <span>Scan</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-value">27</span>
          <span class="stat-label">Source Files</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">8</span>
          <span class="stat-label">Modules</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">7</span>
          <span class="stat-label">Themes</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">6</span>
          <span class="stat-label">AI Providers</span>
        </div>
      </div>
    </section>

    <!-- Code Preview -->
    <section class="code-preview">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="terminal-title">terminal</span>
        </div>
        <div class="terminal-body">
          <div class="terminal-line"><span class="prompt">$</span> <span class="cmd">help</span></div>
          <div class="terminal-output">Available commands: help, status, clear, stats, time, history, alias, env, notes, todo, ls, cd, pwd, read, write, mkdir, delete, ping, curl, scan, ai, process, task, macro</div>
          <div class="terminal-line"><span class="prompt">$</span> <span class="cmd">ai What is HELIOS?</span></div>
          <div class="terminal-output">HELIOS is a futuristic AI command system that combines the power of Rust with intelligent AI assistance. It provides real-time system metrics, extensible plugin support, and a professional GUI interface.</div>
          <div class="terminal-line"><span class="prompt">$</span> <span class="cmd">theme neon</span></div>
          <div class="terminal-output">Theme changed to Neon</div>
          <div class="terminal-line"><span class="prompt">$</span> <span class="cursor"></span></div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-content">
        <p class="footer-brand">HELIOS</p>
        <p class="footer-tagline">Built with Rust and egui</p>
        <div class="footer-links">
          <a href="https://github.com/Manavarya09/HELIOS">GitHub</a>
          <a href="https://github.com/Manavarya09/HELIOS/issues">Issues</a>
          <a href="https://github.com/Manavarya09/HELIOS/discussions">Discussions</a>
        </div>
        <p class="footer-copy">Released under the MIT License</p>
      </div>
    </footer>
  </main>
</Layout>

<style is:inline>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #000; color: #fff; font-family: system-ui, -apple-system, sans-serif; line-height: 1.6; }
.container { position: relative; overflow-x: hidden; }
.grid-bg { position: fixed; inset: 0; background-image: linear-gradient(rgba(6, 182, 212, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.03) 1px, transparent 1px); background-size: 50px 50px; pointer-events: none; z-index: 0; }

/* Glow Effects */
.glow { position: fixed; border-radius: 50%; filter: blur(120px); opacity: 0.15; pointer-events: none; z-index: 1; }
.glow-1 { width: 600px; height: 600px; background: #06b6d4; top: -200px; right: -200px; animation: float 20s ease-in-out infinite; }
.glow-2 { width: 500px; height: 500px; background: #8b5cf6; bottom: -150px; left: -150px; animation: float 25s ease-in-out infinite reverse; }
@keyframes float { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(30px, 30px); } }

/* Hero Section */
.hero { position: relative; z-index: 10; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; min-height: 100vh; padding: 4rem; max-width: 1400px; margin: 0 auto; }
.hero-content { text-align: left; }
.badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; font-family: monospace; font-size: 0.875rem; color: #22d3ee; border: 1px solid rgba(34, 211, 238, 0.3); border-radius: 9999px; background: rgba(34, 211, 238, 0.05); margin-bottom: 2rem; }
.badge-dot { width: 6px; height: 6px; background: #22d3ee; border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

.hero-title { font-size: 5rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
.title-line { display: block; background: linear-gradient(135deg, #fff 0%, #22d3ee 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero-subtitle { font-size: 1.5rem; color: #9ca3af; margin-bottom: 1rem; }
.hero-desc { font-size: 1rem; color: #6b7280; max-width: 500px; margin-bottom: 2rem; }

.hero-actions { display: flex; gap: 1rem; }
.btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.5rem; font-size: 1rem; font-weight: 600; text-decoration: none; border-radius: 0.5rem; transition: all 0.2s; }
.btn-primary { background: #06b6d4; color: #000; }
.btn-primary:hover { background: #22d3ee; transform: translateY(-2px); }
.btn-secondary { border: 1px solid #374151; color: #fff; }
.btn-secondary:hover { border-color: #4b5563; background: rgba(255,255,255,0.05); }
.btn-icon { font-size: 1.25rem; }
.btn-arrow { transition: transform 0.2s; }
.btn-secondary:hover .btn-arrow { transform: translateX(4px); }

/* Hero Visual */
.hero-visual { display: flex; justify-content: center; }
.visual-frame { width: 100%; max-width: 400px; border: 1px solid #1f2937; border-radius: 0.75rem; background: rgba(17, 24, 39, 0.8); overflow: hidden; }
.frame-header { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: #111827; border-bottom: 1px solid #1f2937; }
.frame-dots { display: flex; gap: 0.5rem; }
.frame-dots span { width: 10px; height: 10px; border-radius: 50%; background: #374151; }
.frame-dots span:first-child { background: #ef4444; }
.frame-dots span:nth-child(2) { background: #eab308; }
.frame-dots span:nth-child(3) { background: #22c55e; }
.frame-title { font-size: 0.875rem; color: #6b7280; }
.frame-body { padding: 1.5rem; }
.metrics-grid { display: grid; gap: 1rem; }
.metric { display: grid; grid-template-columns: 40px 1fr 50px; align-items: center; gap: 0.75rem; }
.metric-label { font-size: 0.75rem; color: #6b7280; font-family: monospace; }
.metric-bar { height: 8px; background: #1f2937; border-radius: 4px; overflow: hidden; }
.metric-fill { height: 100%; background: linear-gradient(90deg, #06b6d4, #22d3ee); border-radius: 4px; }
.metric-value { font-size: 0.875rem; color: #fff; font-family: monospace; text-align: right; }

/* Section Header */
.section-header { text-align: center; margin-bottom: 4rem; }
.section-header h2 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; }
.section-desc { color: #6b7280; font-size: 1.125rem; }

/* About Section */
.about { position: relative; z-index: 10; padding: 6rem 4rem; max-width: 1200px; margin: 0 auto; }
.about-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.about-card { padding: 1.5rem; border: 1px solid #1f2937; border-radius: 0.75rem; background: rgba(17, 24, 39, 0.5); transition: all 0.3s; }
.about-card:hover { border-color: #06b6d4; transform: translateY(-4px); }
.about-icon { width: 48px; height: 48px; margin-bottom: 1rem; }
.icon-frame { width: 48px; height: 48px; border: 2px solid #06b6d4; border-radius: 8px; position: relative; }
.icon-frame::after { content: ''; position: absolute; inset: 8px; border: 1px solid rgba(6, 182, 212, 0.3); border-radius: 4px; }
.about-card h3 { font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; }
.about-card p { font-size: 0.875rem; color: #6b7280; }

/* Features Section */
.features { position: relative; z-index: 10; padding: 6rem 4rem; max-width: 1400px; margin: 0 auto; }
.features-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.feature-card { padding: 1.5rem; border: 1px solid #1f2937; border-radius: 0.75rem; background: rgba(17, 24, 39, 0.5); transition: all 0.3s; }
.feature-card:hover { border-color: #06b6d4; }
.feature-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
.feature-num { font-size: 0.75rem; color: #06b6d4; font-family: monospace; }
.feature-card h3 { font-size: 1.125rem; font-weight: 600; }
.feature-card p { font-size: 0.875rem; color: #6b7280; margin-bottom: 1rem; }
.feature-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.feature-tags span { font-size: 0.75rem; padding: 0.25rem 0.5rem; background: #1f2937; border-radius: 4px; color: #9ca3af; }

/* Stats Section */
.stats { position: relative; z-index: 10; padding: 4rem; border-top: 1px solid #1f2937; border-bottom: 1px solid #1f2937; }
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; max-width: 800px; margin: 0 auto; text-align: center; }
.stat-item { text-align: center; }
.stat-value { display: block; font-size: 3rem; font-weight: 700; color: #06b6d4; }
.stat-label { font-size: 0.875rem; color: #6b7280; }

/* Terminal */
.code-preview { position: relative; z-index: 10; padding: 6rem 4rem; }
.terminal { max-width: 800px; margin: 0 auto; border: 1px solid #1f2937; border-radius: 0.75rem; overflow: hidden; }
.terminal-header { display: flex; align-items: center; padding: 0.75rem 1rem; background: #111827; border-bottom: 1px solid #1f2937; }
.terminal-dots { display: flex; gap: 0.5rem; }
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot.red { background: #ef4444; }
.dot.yellow { background: #eab308; }
.dot.green { background: #22c55e; }
.terminal-title { margin-left: 1rem; font-size: 0.875rem; color: #6b7280; }
.terminal-body { padding: 1.5rem; background: #000; font-family: monospace; font-size: 0.875rem; line-height: 1.8; }
.terminal-line { display: flex; }
.prompt { color: #6b7280; margin-right: 0.5rem; }
.cmd { color: #22d3ee; }
.terminal-output { color: #9ca3af; margin-left: 1rem; margin-bottom: 0.5rem; }
.cursor { width: 8px; height: 1rem; background: #22d3ee; animation: blink 1s step-end infinite; }
@keyframes blink { 50% { opacity: 0; } }

/* Footer */
.footer { position: relative; z-index: 10; padding: 4rem; border-top: 1px solid #1f2937; text-align: center; }
.footer-content { max-width: 600px; margin: 0 auto; }
.footer-brand { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
.footer-tagline { font-size: 0.875rem; color: #6b7280; margin-bottom: 1.5rem; }
.footer-links { display: flex; justify-content: center; gap: 2rem; margin-bottom: 1.5rem; }
.footer-links a { color: #9ca3af; text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: #fff; }
.footer-copy { font-size: 0.75rem; color: #4b5563; }

/* Responsive */
@media (max-width: 1024px) {
  .hero { grid-template-columns: 1fr; text-align: center; }
  .hero-content { text-align: center; }
  .hero-desc { margin: 0 auto 2rem; }
  .hero-actions { justify-content: center; }
  .hero-visual { display: none; }
  .about-grid { grid-template-columns: repeat(2, 1fr); }
  .features-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .hero { padding: 2rem; }
  .hero-title { font-size: 3rem; }
  .about-grid { grid-template-columns: 1fr; }
  .features-grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>